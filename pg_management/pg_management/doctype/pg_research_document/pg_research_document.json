{
    "name": "PG Research Document",
    "module": "PG Management",
    "custom": 0,
    "autoname": "naming_series:",
    "fields": [
        {
            "fieldname": "naming_series",
            "label": "Naming Series",
            "fieldtype": "Select",
            "options": "DOC-YYYY-.####",
            "default": "DOC-YYYY-."
        },
        {
            "fieldname": "student",
            "label": "Student Record",
            "fieldtype": "Link",
            "options": "PG Student Record",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "document_type",
            "label": "Document Type",
            "fieldtype": "Select",
            "options": "Proposal\nProgress Report\nEvaluation Form\nExaminer Report\nPublication\nThesis",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "title",
            "label": "Title",
            "fieldtype": "Data",
            "reqd": 1
        },
        {
            "fieldname": "file",
            "label": "File",
            "fieldtype": "Attach",
            "reqd": 1
        },
        {
            "fieldname": "upload_date",
            "label": "Upload Date",
            "fieldtype": "Date"
        },
        {
            "fieldname": "version",
            "label": "Version",
            "fieldtype": "Data",
            "default": "1.0"
        }
    ],
    "doctype": "DocType",
    "permissions": [
        {
            "role": "PG Coordinator",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "PG Head of Department",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "PG Supervisor",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "PG Student",
            "read": 1
        },
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        }
    ]
}