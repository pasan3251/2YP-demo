{
    "name": "PG Final Thesis Submission",
    "module": "PG Management",
    "custom": 0,
    "is_submittable": 1,
    "autoname": "naming_series:",
    "fields": [
        {
            "fieldname": "naming_series",
            "label": "Naming Series",
            "fieldtype": "Select",
            "options": "FTS-YYYY-.####",
            "default": "FTS-YYYY-."
        },
        {
            "fieldname": "student",
            "label": "Student Record",
            "fieldtype": "Link",
            "options": "PG Student Record",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "original_submission",
            "label": "Original Submission",
            "fieldtype": "Link",
            "options": "PG Thesis Submission"
        },
        {
            "fieldname": "final_document",
            "label": "Final Thesis Document",
            "fieldtype": "Attach",
            "reqd": 1
        },
        {
            "fieldname": "status",
            "label": "Status",
            "fieldtype": "Select",
            "options": "Draft\nSubmitted\nArchived",
            "default": "Draft",
            "in_list_view": 1
        }
    ],
    "doctype": "DocType",
    "permissions": [
        {
            "role": "PG Coordinator",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "PG Head of Department",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "PG Supervisor",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "PG Student",
            "read": 1,
            "write": 1,
            "create": 1,
            "submit": 1
        },
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        }
    ]
}