{
    "name": "PG Research Proposal",
    "module": "PG Management",
    "custom": 0,
    "is_submittable": 1,
    "autoname": "naming_series:",
    "fields": [
        {
            "fieldname": "naming_series",
            "label": "Naming Series",
            "fieldtype": "Select",
            "options": "PROP-YYYY-.####",
            "default": "PROP-YYYY-."
        },
        {
            "fieldname": "applicant",
            "label": "Applicant",
            "fieldtype": "Link",
            "options": "PG Applicant",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "title",
            "label": "Proposal Title",
            "fieldtype": "Data",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "document",
            "label": "Proposal Document",
            "fieldtype": "Attach",
            "reqd": 1
        },
        {
            "fieldname": "status",
            "label": "Status",
            "fieldtype": "Select",
            "options": "Draft\nSubmitted\nUnder Review\nEvaluated",
            "default": "Draft",
            "in_list_view": 1
        }
    ],
    "doctype": "DocType",
    "permissions": [
        {
            "role": "PG Coordinator",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "PG Head of Department",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "PG Supervisor",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "PG Student",
            "read": 1,
            "write": 1,
            "create": 1,
            "submit": 1
        },
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        }
    ]
}